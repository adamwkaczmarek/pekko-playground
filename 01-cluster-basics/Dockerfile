# =============================================================================
# Multi-stage Dockerfile for the Pekko Cluster demo.
#
# Stage 1: build the fat-jar / staged application with sbt
# Stage 2: fetch the JMX Prometheus exporter jar
# Stage 3: minimal runtime image
#
# Build:
#   docker build -t pekko-playground:latest .
#
# Run a single node (for quick smoke test — not a real cluster):
#   docker run --rm \
#     -e PEKKO_HOSTNAME=127.0.0.1 \
#     -e POD_IP=127.0.0.1 \
#     -p 25520:25520 -p 8558:8558 -p 9090:9090 \
#     pekko-playground:latest
# =============================================================================

# ---- Stage 1: Build ---------------------------------------------------------
FROM eclipse-temurin:23-jdk-jammy AS build

# Install sbt
RUN apt-get update && apt-get install -y curl gnupg && \
    echo "deb https://repo.scala-sbt.org/scalasbt/debian all main" \
      > /etc/apt/sources.list.d/sbt.list && \
    curl -sL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x99E82A75642AC823" \
      | gpg --no-default-keyring --keyring gnupg-ring:/etc/apt/trusted.gpg.d/scalasbt.gpg --import && \
    chmod 644 /etc/apt/trusted.gpg.d/scalasbt.gpg && \
    apt-get update && apt-get install -y sbt && \
    rm -rf /var/lib/apt/lists/*

WORKDIR /build
# Cache dependencies before copying full source
COPY build.sbt .
COPY project/ project/
RUN sbt update

COPY src/ src/
RUN sbt stage

# ---- Stage 2: JMX Exporter --------------------------------------------------
FROM eclipse-temurin:23-jre-jammy AS jmx
RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*
RUN curl -fsSL \
  "https://repo1.maven.org/maven2/io/prometheus/jmx/jmx_prometheus_javaagent/0.20.0/jmx_prometheus_javaagent-0.20.0.jar" \
  -o /jmx_prometheus_javaagent.jar

# ---- Stage 3: Runtime -------------------------------------------------------
FROM eclipse-temurin:23-jre-jammy

WORKDIR /app

# Application distribution (sbt-native-packager stage output)
COPY --from=build /build/target/universal/stage /app

# JMX exporter agent + config
COPY --from=jmx  /jmx_prometheus_javaagent.jar   /app/jmx_prometheus_javaagent.jar
COPY docker/jmx-config.yaml                        /app/jmx-config.yaml

# Pekko Cluster:  25520 = Artery (cluster transport)
# Management:      8558 = HTTP management API
# JMX exporter:   9090 = Prometheus scrape endpoint
EXPOSE 25520 8558 9090

# Attach the JMX exporter as a Java agent.
# The start script generated by sbt-native-packager honours JAVA_OPTS.
# Java 9+ JPMS: Pekko and Jackson use reflection to access JDK internals.
# These --add-opens flags suppress the resulting IllegalAccessErrors on Java 23.
ENV JAVA_OPTS="\
  -javaagent:/app/jmx_prometheus_javaagent.jar=9090:/app/jmx-config.yaml \
  -Xmx512m \
  --add-opens=java.base/java.lang=ALL-UNNAMED \
  --add-opens=java.base/java.io=ALL-UNNAMED \
  --add-opens=java.base/java.util=ALL-UNNAMED \
  --add-opens=java.base/java.util.concurrent=ALL-UNNAMED \
  --add-opens=java.base/java.util.concurrent.atomic=ALL-UNNAMED \
  --add-opens=java.base/sun.nio.ch=ALL-UNNAMED"

# Use the kubernetes.conf overlay when running in a container
ENV CONFIG_RESOURCE="kubernetes.conf"
ENV JVM_FLAGS="-Dconfig.resource=${CONFIG_RESOURCE}"

# Entry point is the generated start script (name = build.sbt `name` field)
ENTRYPOINT ["/bin/sh", "-c", "exec /app/bin/pekko-playground ${JVM_FLAGS} $@"]
