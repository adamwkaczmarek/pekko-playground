{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "description": "JVM and Pekko Cluster metrics via JMX Prometheus Exporter",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "title": "JVM Heap Used",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_memory_heap_used_bytes{namespace=\"pekko-demo\"}",
          "legendFormat": "heap used – {{pod}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_heap_max_bytes{namespace=\"pekko-demo\"}",
          "legendFormat": "heap max – {{pod}}",
          "refId": "B"
        }
      ]
    },

    {
      "id": 2,
      "title": "GC Pause Rate (collections / sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_total{namespace=\"pekko-demo\"}[1m])",
          "legendFormat": "{{gc}} – {{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 3,
      "title": "JVM Thread Count",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "jvm_threads_threadcount{namespace=\"pekko-demo\"}",
          "legendFormat": "threads – {{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 4,
      "title": "Process CPU Load",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "jvm_os_processcpuload{namespace=\"pekko-demo\"}",
          "legendFormat": "cpu – {{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 5,
      "title": "Pekko Dispatcher — Active Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Number of threads actively executing tasks in each Pekko dispatcher. The default-dispatcher is where most actor code runs.",
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "pekko_dispatcher_activethreadcount{namespace=\"pekko-demo\"}",
          "legendFormat": "{{dispatcher}} – {{pod}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 6,
      "title": "Memory Pool Usage",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 268435456 },
              { "color": "red",    "value": 402653184 }
            ]
          }
        }
      },
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "jvm_memory_pool_used_bytes{namespace=\"pekko-demo\"}",
          "legendFormat": "{{pool}}",
          "refId": "A"
        }
      ]
    },

    {
      "id": 7,
      "title": "GC Total Time (rate, ms/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(jvm_gc_collection_seconds_total{namespace=\"pekko-demo\"}[1m]) * 1000",
          "legendFormat": "{{gc}} – {{pod}}",
          "refId": "A"
        }
      ]
    }

  ],

  "refresh": "15s",
  "schemaVersion": 38,
  "tags": ["pekko", "jvm", "cluster"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Data Source"
      }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Pekko Cluster — JVM Metrics",
  "uid": "pekko-cluster-jvm",
  "version": 1
}
