<configuration>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} %-5level [%thread] %logger{30} - %msg%n</pattern>
    </encoder>
  </appender>

  <logger name="org.apache.pekko.cluster"          level="INFO"/>
  <logger name="org.apache.pekko.cluster.sbr"      level="INFO"/>
  <logger name="org.apache.pekko.cluster.sharding" level="INFO"/>
  <logger name="org.apache.pekko.management"       level="INFO"/>
  <logger name="org.apache.pekko.remote"           level="WARN"/>
  <logger name="org.apache.pekko.http"             level="WARN"/>

  <!-- Our application code -->
  <logger name="com.example" level="DEBUG"/>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

</configuration>
